DATABASE_URL=postgresql://postgres:password@localhost:5432/scoutiq
JWT_SECRET_KEY=change-this-to-a-random-secret-at-least-32-characters-long
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
ALLOWED_ORIGINS=http://localhost:8080
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8080/auth/google/callback
GMAIL_USER=your-gmail-address@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password
FRONTEND_URL=http://localhost:8080
GROQ_API_KEY=your-groq-api-key
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
# Telegram delivery mode: "polling" (dev, default) or "webhook" (production).
# Webhook mode requires a public HTTPS URL and a secret token.
TELEGRAM_MODE=polling
TELEGRAM_WEBHOOK_BASE_URL=            # e.g. https://api.yourdomain.com (no trailing slash)
TELEGRAM_WEBHOOK_SECRET=             # random token, chars A-Z a-z 0-9 _ - (1–256); sent by Telegram as a header

# Set DEBUG=false in production. The app refuses to start with DEBUG=false if
# JWT_SECRET_KEY is weak/default or ALLOWED_ORIGINS still points at localhost.
DEBUG=true

# Security hardening
LOGIN_MAX_FAILED_ATTEMPTS=5        # account locks after this many consecutive failures
LOGIN_LOCKOUT_MINUTES=15
MAX_REQUEST_BODY_BYTES=8388608     # 8 MB global request-body cap
ENABLE_HSTS=false                  # set true only when served over HTTPS in production

# AI cost controls (Groq free tier)
AI_DAILY_REQUEST_LIMIT=50          # per-scout per-day
AI_REQUESTS_PER_MINUTE=10          # per-scout per-minute
AI_GLOBAL_DAILY_REQUEST_LIMIT=2000 # shared ceiling across all scouts per day
# AI access is off by default per scout; a Global Admin grants it in Admin → Users.
